{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    ':disableDependencyDashboard',
    ':disableRateLimiting',
  ],
  customManagers: [
    // Update the JDK version in .sdkmanrc with the latest Temurin release.
    {
      customType: 'regex',
      fileMatch: [
        '^\\.sdkmanrc$',
      ],
      // The "-tem" (Temurin) vendor suffix is kept outside the capture group so
      // it is preserved on update; Renovate does not understand SDKMAN! suffixes.
      matchStrings: [
        'java=(?<currentValue>.*)-tem\\n',
      ],
      datasourceTemplate: 'java-version',
      depNameTemplate: 'java',
      // Strip the "+build" suffix the Temurin API returns; SDKMAN! omits it.
      extractVersionTemplate: '^(?<version>[^+]+)',
    },
  ],
  packageRules: [
    // Pin `androidx.core:core[-ktx]` to 1.16.0. Newer releases (1.17.0+) bump the required Android
    // Gradle plugin version, which would force consumers onto AGP 9.
    // See https://github.com/JuulLabs/kable/issues/1206.
    {
      matchPackageNames: [
        'androidx.core:core',
        'androidx.core:core-ktx',
      ],
      allowedVersions: '1.16.0',
    },
  ],
}
